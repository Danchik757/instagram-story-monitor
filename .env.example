# Instagram настройки
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# Telegram настройки
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Список отслеживаемых аккаунтов (через запятую, без @)
TRACKED_ACCOUNTS=friend1,friend2,friend3

# Интервалы проверки
CHECK_INTERVAL_HOURS=4
INTERVAL_RANDOMNESS_MINUTES=30

# Настройки безопасности
MIN_DELAY_SECONDS=10
MAX_DELAY_SECONDS=30
MAX_STORIES_PER_CHECK=10

# VPN настройки (опционально)
USE_VPN=false
VPN_CONFIG_PATH=./config/wireguard.conf

# Режим работы
CATCH_UP_MODE=true  # Догонять пропущенные stories при запуске
DEBUG_MODE=false